# Backend API base URL (required for auth, dashboards, and charts)
# Use your backend URL including /api for separated frontend/backend setup.
VITE_API_BASE_URL=http://127.0.0.1:8000/api
## Alternate
# VITE_API_BASE_URL=http://localhost:8000/api

# Optional: override auth paths (defaults shown)
# VITE_AUTH_LOGIN_PATH=/student/login
# VITE_AUTH_REGISTER_PATH=/register
# VITE_AUTH_LOGOUT_PATH=/logout

# Optional: OpenWeather API key for weather widget on student dashboard
# VITE_OPENWEATHER_API_KEY=your_key_here
#wenibrando